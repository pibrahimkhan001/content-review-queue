PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=content_review_queue
DB_USER=crq_user
DB_PASSWORD=crq_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — change this to a long random string in production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h

# Reservation window in seconds (1200 = 20 minutes)
RESERVATION_TTL_SECONDS=1200
