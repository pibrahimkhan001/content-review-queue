PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=content_review_queue
DB_USER=crq_user
DB_PASSWORD=crq_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_prod
